PORT=3000
NODE_ENV=development

# Required in production (asserted at startup)
JWT_SECRET=change-this-to-a-long-random-string
JWT_SECRET_ADMIN=change-this-to-a-different-long-random-string

# First admin (only when admins table is empty); or use: node scripts/create-admin.js <email> <password>
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# Existing admin: node scripts/reset-admin-password.js <email> <new-password>
# See who exists: node scripts/list-admins.js

# CORS: comma-separated browser origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_ENTERPRISE=

# Optional: encrypt SMTP password at rest (any long random string)
# CREDENTIALS_ENCRYPTION_KEY=

# Dev only: allow token exchange from localhost for any siteId (testing embedded snippet locally)
# ALLOW_INSECURE_LICENSE_ORIGIN=true

# Emergency only: allow POST /api/license/track with licenseKey (insecure)
# ALLOW_LEGACY_LICENSE_TRACK=true

# Stricter CSP (may break inline handlers in static HTML unless refactored)
# CSP_ALLOW_UNSAFE_INLINE=false
